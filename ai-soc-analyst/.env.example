# ============================================================
# AI-Powered SOC Analyst — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
# ============================================================

# --- Backend ---
APP_NAME=AI-Powered SOC Analyst
DEBUG=True

# --- Database ---
# SQLite is used during development. Switch to PostgreSQL for production.
DATABASE_URL=sqlite:///./soc_analyst.db

# --- Frontend URL (for CORS) ---
FRONTEND_URL=http://localhost:5173

# --- Google Gemini API (Sprint 2+) ---
GEMINI_API_KEY=

# --- ChromaDB (Sprint 2+) ---
CHROMA_PERSIST_DIR=./knowledge_base/store/chroma_db
